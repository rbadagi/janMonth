Dictionary KT

# Python Dictionary Functions - Complete Reference

---

## 1. Creating Dictionaries

```python
# Empty dictionary
empty = {}
empty = dict()

# With key-value pairs
person = {"name": "Alice", "age": 30, "city": "New York"}

# Using dict() constructor
person = dict(name="Alice", age=30, city="New York")

# From list of tuples
pairs = dict([("name", "Alice"), ("age", 30), ("city", "New York")])

# From two lists using zip
keys = ["name", "age", "city"]
values = ["Alice", 30, "New York"]
person = dict(zip(keys, values))

# Using fromkeys()
keys = ["a", "b", "c"]
default_dict = dict.fromkeys(keys, 0)
print(default_dict)  # {'a': 0, 'b': 0, 'c': 0}

# Dictionary comprehension
squares = {x: x**2 for x in range(1, 6)}
print(squares)  # {1: 1, 2: 4, 3: 9, 4: 16, 5: 25}
```

---

## 2. Accessing Elements

### Direct Access []
```python
person = {"name": "Alice", "age": 30, "city": "New York"}
print(person["name"])  # Alice
print(person["age"])   # 30

# person["phone"]  # KeyError: 'phone'
```

### get()
Returns the value for a key. Returns default (None) if key not found.
```python
person = {"name": "Alice", "age": 30, "city": "New York"}

print(person.get("name"))       # Alice
print(person.get("phone"))      # None (no error)
print(person.get("phone", "N/A"))  # N/A (custom default)
```

### setdefault()
Returns value if key exists. If not, inserts key with a default value and returns it.
```python
person = {"name": "Alice", "age": 30}

# Key exists - returns existing value
print(person.setdefault("name", "Bob"))  # Alice

# Key doesn't exist - inserts and returns default
print(person.setdefault("city", "New York"))  # New York
print(person)  # {'name': 'Alice', 'age': 30, 'city': 'New York'}

# Without default value - inserts None
print(person.setdefault("phone"))  # None
print(person)  # {'name': 'Alice', 'age': 30, 'city': 'New York', 'phone': None}
```

---

## 3. Adding and Updating Elements

### Direct Assignment []
```python
person = {"name": "Alice", "age": 30}

# Add new key
person["city"] = "New York"
print(person)  # {'name': 'Alice', 'age': 30, 'city': 'New York'}

# Update existing key
person["age"] = 31
print(person)  # {'name': 'Alice', 'age': 31, 'city': 'New York'}
```

### update()
Updates dictionary with key-value pairs from another dictionary or iterable.
```python
person = {"name": "Alice", "age": 30}

# Update with another dictionary
person.update({"age": 31, "city": "New York"})
print(person)  # {'name': 'Alice', 'age': 31, 'city': 'New York'}

# Update with keyword arguments
person.update(phone="123-456", email="alice@email.com")
print(person)
# {'name': 'Alice', 'age': 31, 'city': 'New York', 'phone': '123-456', 'email': 'alice@email.com'}

# Update with list of tuples
person.update([("country", "USA"), ("zip", "10001")])
print(person["country"])  # USA
```

### Merge Operator | (Python 3.9+)
```python
dict1 = {"a": 1, "b": 2}
dict2 = {"b": 3, "c": 4}

# Create new merged dictionary
merged = dict1 | dict2
print(merged)  # {'a': 1, 'b': 3, 'c': 4}

# In-place merge
dict1 |= dict2
print(dict1)  # {'a': 1, 'b': 3, 'c': 4}
```

---

## 4. Removing Elements

### pop()
Removes and returns the value for a specified key. Raises KeyError if key not found (unless default provided).
```python
person = {"name": "Alice", "age": 30, "city": "New York"}

removed = person.pop("age")
print(removed)  # 30
print(person)   # {'name': 'Alice', 'city': 'New York'}

# With default value (no error if key missing)
result = person.pop("phone", "Not found")
print(result)  # Not found

# person.pop("phone")  # KeyError: 'phone'
```

### popitem()
Removes and returns the last inserted key-value pair as a tuple. Raises KeyError if empty.
```python
person = {"name": "Alice", "age": 30, "city": "New York"}

last_item = person.popitem()
print(last_item)  # ('city', 'New York')
print(person)     # {'name': 'Alice', 'age': 30}

# empty = {}
# empty.popitem()  # KeyError: 'popitem(): dictionary is empty'
```

### del statement
Deletes a key-value pair or the entire dictionary.
```python
person = {"name": "Alice", "age": 30, "city": "New York"}

del person["age"]
print(person)  # {'name': 'Alice', 'city': 'New York'}

# del person["phone"]  # KeyError: 'phone'

# Delete entire dictionary
# del person
# print(person)  # NameError: name 'person' is not defined
```

### clear()
Removes all key-value pairs from the dictionary.
```python
person = {"name": "Alice", "age": 30, "city": "New York"}
person.clear()
print(person)  # {}
```

---

## 5. Dictionary Views

### keys()
Returns a view object of all keys.
```python
person = {"name": "Alice", "age": 30, "city": "New York"}
keys = person.keys()
print(keys)       # dict_keys(['name', 'age', 'city'])
print(list(keys)) # ['name', 'age', 'city']

# View is dynamic - reflects changes
person["phone"] = "123-456"
print(keys)  # dict_keys(['name', 'age', 'city', 'phone'])
```

### values()
Returns a view object of all values.
```python
person = {"name": "Alice", "age": 30, "city": "New York"}
values = person.values()
print(values)       # dict_values(['Alice', 30, 'New York'])
print(list(values)) # ['Alice', 30, 'New York']
```

### items()
Returns a view object of all key-value pairs as tuples.
```python
person = {"name": "Alice", "age": 30, "city": "New York"}
items = person.items()
print(items)       # dict_items([('name', 'Alice'), ('age', 30), ('city', 'New York')])
print(list(items)) # [('name', 'Alice'), ('age', 30), ('city', 'New York')]

# Iterating over items
for key, value in person.items():
    print(f"{key}: {value}")
# name: Alice
# age: 30
# city: New York
```

---

## 6. Copying Dictionaries

### copy()
Returns a shallow copy of the dictionary.
```python
original = {"name": "Alice", "age": 30, "hobbies": ["reading", "coding"]}
copied = original.copy()

copied["name"] = "Bob"
print(original["name"])  # Alice (unchanged)

# Shallow copy - nested objects are shared
copied["hobbies"].append("gaming")
print(original["hobbies"])  # ['reading', 'coding', 'gaming'] (affected!)
```

### dict() constructor
```python
original = {"name": "Alice", "age": 30}
copied = dict(original)
```

### Deep copy (for nested dictionaries)
```python
import copy

original = {"name": "Alice", "scores": [85, 90, 95]}
deep = copy.deepcopy(original)

deep["scores"].append(100)
print(original["scores"])  # [85, 90, 95] (not affected)
print(deep["scores"])      # [85, 90, 95, 100]
```

---

## 7. Dictionary fromkeys()

### fromkeys()
Creates a new dictionary with specified keys and a default value.
```python
# With default value
keys = ["name", "age", "city"]
default_dict = dict.fromkeys(keys, "unknown")
print(default_dict)  # {'name': 'unknown', 'age': 'unknown', 'city': 'unknown'}

# Without default value (None)
empty_dict = dict.fromkeys(keys)
print(empty_dict)  # {'name': None, 'age': None, 'city': None}

# From string (each character becomes a key)
char_dict = dict.fromkeys("abc", 0)
print(char_dict)  # {'a': 0, 'b': 0, 'c': 0}

# CAUTION: Mutable default value is shared
bad_dict = dict.fromkeys(["a", "b", "c"], [])
bad_dict["a"].append(1)
print(bad_dict)  # {'a': [1], 'b': [1], 'c': [1]} (all share same list!)
```

---

## 8. Built-in Functions for Dictionaries

### len()
Returns the number of key-value pairs.
```python
person = {"name": "Alice", "age": 30, "city": "New York"}
print(len(person))  # 3
```

### max()
Returns the maximum key (or value with key function).
```python
scores = {"Alice": 85, "Bob": 92, "Charlie": 78}

# Max key (alphabetical)
print(max(scores))  # Charlie

# Max by value
print(max(scores, key=scores.get))  # Bob

# Max of values
print(max(scores.values()))  # 92
```

### min()
Returns the minimum key (or value with key function).
```python
scores = {"Alice": 85, "Bob": 92, "Charlie": 78}

# Min key
print(min(scores))  # Alice

# Min by value
print(min(scores, key=scores.get))  # Charlie

# Min of values
print(min(scores.values()))  # 78
```

### sum()
Returns the sum of keys (if numeric) or values.
```python
numbers = {1: "one", 2: "two", 3: "three"}
print(sum(numbers))          # 6 (sum of keys)

scores = {"Alice": 85, "Bob": 92, "Charlie": 78}
print(sum(scores.values()))  # 255 (sum of values)
```

### sorted()
Returns a sorted list of keys (or items with key function).
```python
person = {"city": "New York", "name": "Alice", "age": 30}

# Sort keys
print(sorted(person))  # ['age', 'city', 'name']

# Sort by values
scores = {"Alice": 85, "Bob": 92, "Charlie": 78}
print(sorted(scores, key=scores.get))  # ['Charlie', 'Alice', 'Bob']
print(sorted(scores, key=scores.get, reverse=True))  # ['Bob', 'Alice', 'Charlie']

# Sort items by value
sorted_items = sorted(scores.items(), key=lambda x: x[1])
print(sorted_items)  # [('Charlie', 78), ('Alice', 85), ('Bob', 92)]
```

### any()
Returns True if any key is True.
```python
print(any({0: "zero", 1: "one"}))     # True (key 1 is truthy)
print(any({0: "zero", "": "empty"}))  # False (0 and "" are falsy)
```

### all()
Returns True if all keys are True.
```python
print(all({1: "one", 2: "two"}))      # True
print(all({0: "zero", 1: "one"}))     # False (key 0 is falsy)
```

### type()
Returns the type of the object.
```python
d = {"a": 1}
print(type(d))  # <class 'dict'>
```

### isinstance()
Checks if object is a dictionary.
```python
d = {"a": 1}
print(isinstance(d, dict))  # True
```

---

## 9. Membership and Iteration

### Membership (in / not in)
Checks for key existence.
```python
person = {"name": "Alice", "age": 30, "city": "New York"}

print("name" in person)       # True
print("phone" not in person)  # True
print("Alice" in person)      # False (checks keys, not values)

# Check in values
print("Alice" in person.values())  # True
```

### Iterating Over Dictionaries
```python
person = {"name": "Alice", "age": 30, "city": "New York"}

# Iterate over keys (default)
for key in person:
    print(key)
# name, age, city

# Iterate over values
for value in person.values():
    print(value)
# Alice, 30, New York

# Iterate over key-value pairs
for key, value in person.items():
    print(f"{key}: {value}")
# name: Alice
# age: 30
# city: New York
```

---

## 10. Dictionary Comprehensions

### Basic Comprehension
```python
squares = {x: x**2 for x in range(1, 6)}
print(squares)  # {1: 1, 2: 4, 3: 9, 4: 16, 5: 25}
```

### With Condition
```python
even_squares = {x: x**2 for x in range(1, 11) if x % 2 == 0}
print(even_squares)  # {2: 4, 4: 16, 6: 36, 8: 64, 10: 100}
```

### Swapping Keys and Values
```python
original = {"a": 1, "b": 2, "c": 3}
swapped = {v: k for k, v in original.items()}
print(swapped)  # {1: 'a', 2: 'b', 3: 'c'}
```

### From Two Lists
```python
keys = ["name", "age", "city"]
values = ["Alice", 30, "New York"]
person = {k: v for k, v in zip(keys, values)}
print(person)  # {'name': 'Alice', 'age': 30, 'city': 'New York'}
```

### Filtering Dictionary
```python
scores = {"Alice": 85, "Bob": 92, "Charlie": 78, "David": 95}
high_scores = {k: v for k, v in scores.items() if v >= 90}
print(high_scores)  # {'Bob': 92, 'David': 95}
```

### Transforming Values
```python
prices = {"apple": 1.5, "banana": 0.75, "cherry": 2.0}
discounted = {k: round(v * 0.9, 2) for k, v in prices.items()}
print(discounted)  # {'apple': 1.35, 'banana': 0.68, 'cherry': 1.8}
```

---

## 11. Nested Dictionaries

### Creating Nested Dictionaries
```python
students = {
    "Alice": {"age": 20, "grade": "A", "courses": ["Math", "Science"]},
    "Bob": {"age": 22, "grade": "B", "courses": ["English", "History"]},
    "Charlie": {"age": 21, "grade": "A", "courses": ["Math", "English"]}
}
```

### Accessing Nested Values
```python
print(students["Alice"]["grade"])        # A
print(students["Bob"]["courses"][0])     # English
print(students["Charlie"]["age"])        # 21
```

### Modifying Nested Values
```python
students["Alice"]["grade"] = "A+"
students["Bob"]["courses"].append("Art")
print(students["Alice"]["grade"])       # A+
print(students["Bob"]["courses"])       # ['English', 'History', 'Art']
```

### Iterating Nested Dictionaries
```python
for name, info in students.items():
    print(f"\n{name}:")
    for key, value in info.items():
        print(f"  {key}: {value}")
```

