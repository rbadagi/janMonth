## 12. DefaultDict (from collections)

```python
from collections import defaultdict

# Default value of int (0)
word_count = defaultdict(int)
words = ["apple", "banana", "apple", "cherry", "banana", "apple"]
for word in words:
    word_count[word] += 1
print(dict(word_count))  # {'apple': 3, 'banana': 2, 'cherry': 1}

# Default value of list
grouped = defaultdict(list)
students = [("Math", "Alice"), ("Science", "Bob"), ("Math", "Charlie")]
for subject, name in students:
    grouped[subject].append(name)
print(dict(grouped))  # {'Math': ['Alice', 'Charlie'], 'Science': ['Bob']}

# Default value of set
unique_grouped = defaultdict(set)
data = [("a", 1), ("b", 2), ("a", 1), ("a", 3)]
for key, value in data:
    unique_grouped[key].add(value)
print(dict(unique_grouped))  # {'a': {1, 3}, 'b': {2}}
```

---

## 13. OrderedDict (from collections)

```python
from collections import OrderedDict

# Maintains insertion order (default dict does too in Python 3.7+)
ordered = OrderedDict()
ordered["banana"] = 3
ordered["apple"] = 1
ordered["cherry"] = 2
print(ordered)  # OrderedDict([('banana', 3), ('apple', 1), ('cherry', 2)])

# Move to end
ordered.move_to_end("banana")
print(ordered)  # OrderedDict([('apple', 1), ('cherry', 2), ('banana', 3)])

# Move to beginning
ordered.move_to_end("banana", last=False)
print(ordered)  # OrderedDict([('banana', 3), ('apple', 1), ('cherry', 2)])

# Pop last item
print(ordered.popitem())           # ('cherry', 2)

# Pop first item
print(ordered.popitem(last=False)) # ('banana', 3)
```

---

## 14. Counter (from collections)

```python
from collections import Counter

# Count elements
words = ["apple", "banana", "apple", "cherry", "banana", "apple"]
count = Counter(words)
print(count)  # Counter({'apple': 3, 'banana': 2, 'cherry': 1})

# Count characters in string
char_count = Counter("hello world")
print(char_count)  # Counter({'l': 3, 'o': 2, 'h': 1, 'e': 1, ...})

# Most common elements
print(count.most_common(2))  # [('apple', 3), ('banana', 2)]

# Arithmetic operations
c1 = Counter(a=3, b=1)
c2 = Counter(a=1, b=2)
print(c1 + c2)  # Counter({'a': 4, 'b': 3})
print(c1 - c2)  # Counter({'a': 2})

# Total count
print(count.total())  # 6 (Python 3.10+)

# Elements iterator
print(list(count.elements()))  # ['apple', 'apple', 'apple', 'banana', 'banana', 'cherry']
```

---

## 15. ChainMap (from collections)

```python
from collections import ChainMap

defaults = {"color": "red", "size": "medium", "font": "Arial"}
user_settings = {"color": "blue", "font": "Helvetica"}

# ChainMap searches in order
settings = ChainMap(user_settings, defaults)
print(settings["color"])  # blue (from user_settings)
print(settings["size"])   # medium (from defaults)
print(settings["font"])   # Helvetica (from user_settings)

# Get all keys
print(list(settings.keys()))  # ['color', 'size', 'font']
```

---

## 16. Practical Use Cases

### Counting Word Frequency
```python
text = "the cat sat on the mat the cat"
words = text.split()
frequency = {}
for word in words:
    frequency[word] = frequency.get(word, 0) + 1
print(frequency)  # {'the': 3, 'cat': 2, 'sat': 1, 'on': 1, 'mat': 1}
```

### Grouping Data
```python
students = [
    {"name": "Alice", "grade": "A"},
    {"name": "Bob", "grade": "B"},
    {"name": "Charlie", "grade": "A"},
    {"name": "David", "grade": "B"},
]

grouped = {}
for student in students:
    grade = student["grade"]
    grouped.setdefault(grade, []).append(student["name"])
print(grouped)  # {'A': ['Alice', 'Charlie'], 'B': ['Bob', 'David']}
```

### Merging Multiple Dictionaries
```python
dict1 = {"a": 1, "b": 2}
dict2 = {"c": 3, "d": 4}
dict3 = {"e": 5, "f": 6}

# Using unpacking (Python 3.5+)
merged = {**dict1, **dict2, **dict3}
print(merged)  # {'a': 1, 'b': 2, 'c': 3, 'd': 4, 'e': 5, 'f': 6}
```

### Inverting a Dictionary
```python
original = {"a": 1, "b": 2, "c": 3}
inverted = {v: k for k, v in original.items()}
print(inverted)  # {1: 'a', 2: 'b', 3: 'c'}
```

### Dictionary as Switch/Case
```python
def calculate(operator, a, b):
    operations = {
        "+": lambda: a + b,
        "-": lambda: a - b,
        "*": lambda: a * b,
        "/": lambda: a / b if b != 0 else "Division by zero"
    }
    return operations.get(operator, lambda: "Invalid operator")()

print(calculate("+", 10, 5))  # 15
print(calculate("*", 4, 3))   # 12
```

---

## Quick Reference Table

| Method/Function | Description |
|----------------|-------------|
| dict[key] | Access value by key (KeyError if missing) |
| get(key, default) | Access value (returns default if missing) |
| setdefault(key, default) | Get or set default value |
| update(dict2) | Update with another dict |
| pop(key, default) | Remove and return value |
| popitem() | Remove and return last item |
| clear() | Remove all items |
| copy() | Shallow copy |
| keys() | View of all keys |
| values() | View of all values |
| items() | View of all key-value pairs |
| fromkeys(keys, value) | Create dict with default value |
| len(dict) | Number of key-value pairs |
| max(dict) | Maximum key |
| min(dict) | Minimum key |
| sorted(dict) | Sorted list of keys |
| any(dict) | True if any key is True |
| all(dict) | True if all keys are True |
| in (membership) | Check if key exists |
| del dict[key] | Delete key-value pair |
| \| (merge) | Merge dictionaries (Python 3.9+) |
| \|= (update) | In-place merge (Python 3.9+) |
| {**d1, **d2} | Unpack and merge |

